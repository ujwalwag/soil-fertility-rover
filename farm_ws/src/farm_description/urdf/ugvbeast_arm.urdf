  <!-- ros2_control hardware interface for Gazebo Harmonic -->
  <!-- ros2_control hardware interface for Gazebo Harmonic -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    
    <!-- 2 wheel joints for differential drive -->
    <joint name="wheel_left_joint">
      <command_interface name="velocity"><param name="min">-10</param><param name="max">10</param></command_interface>
      <state_interface name="velocity"/><state_interface name="position"/>
    </joint>
    <joint name="wheel_right_joint">
      <command_interface name="velocity"><param name="min">-10</param><param name="max">10</param></command_interface>
      <state_interface name="velocity"/><state_interface name="position"/>
    </joint>
    
    <!-- Arm joints -->
    <joint name="joint1">
      <command_interface name="position">
        <param name="min">-2.827</param>
        <param name="max">2.827</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="joint2">
      <command_interface name="position">
        <param name="min">-1.57</param>
        <param name="max">1.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="joint3">
      <command_interface name="position">
        <param name="min">-1.57</param>
        <param name="max">1.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="joint4">
      <command_interface name="position">
        <param name="min">-1.57</param>
        <param name="max">1.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="gripper_left_joint">
      <command_interface name="position">
        <param name="min">-0.8</param>
        <param name="max">0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="gripper_right_joint">
      <command_interface name="position">
        <param name="min">0</param>
        <param name="max">0.8</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
  
  <!-- Gazebo plugin for ros2_control -->
  <!-- Connects to existing controller_manager node created by ros2_control_node -->
  <!-- For Gazebo Harmonic: Must specify the exact plugin name from the library -->
  <!-- The library contains: gz_ros2_control::GazeboSimROS2ControlPlugin -->
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <controller_manager_prefix_node_name>controller_manager</controller_manager_prefix_node_name>
      <parameters>$(find farm_control)/config/all_controllers.yaml</parameters>
    </plugin>
  </gazebo>
  
</robot>

